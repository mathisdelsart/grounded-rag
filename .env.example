# Copy to `.env` and fill in. The real `.env` is gitignored.

# LLM per role (get_llm factory). Defaults to gpt-4o-mini when unset.
LLM_EXTRACT=gpt-4o-mini
LLM_ROUTER=gpt-4o-mini
LLM_GENERATE=gpt-4o-mini
LLM_GRADE=gpt-4o-mini
LLM_JUDGE=gpt-4o-mini

# Provider API key
OPENAI_API_KEY=

# Infra
QDRANT_URL=http://localhost:6333
DATABASE_URL=sqlite:///./app.db

# Observability (optional, opt-in). Tracing activates only when the public and
# secret keys are set. Requires the `obs` extra: `uv sync --extra obs`.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_HOST=https://cloud.langfuse.com
